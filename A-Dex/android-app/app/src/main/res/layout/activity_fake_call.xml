<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incoming Call"
        android:textColor="#D9E3F0"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/fakeCallCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Unknown Caller"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/fakeCallSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Incoming call"
        android:textColor="#AFC3D6"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="42dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/fakeCallDecline"
            android:layout_width="128dp"
            android:layout_height="52dp"
            android:backgroundTint="#D7263D"
            android:text="Decline"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Space
            android:layout_width="18dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/fakeCallAnswer"
            android:layout_width="128dp"
            android:layout_height="52dp"
            android:backgroundTint="#00A86B"
            android:text="Answer"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
